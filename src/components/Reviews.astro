---
// Static fallback reviews (shown while Elfsight loads or as backup)
const staticReviews = [
  {
    name: 'María García',
    rating: 5,
    date: 'Hace 2 semanas',
    text: 'Un trabajo espectacular. Nos hicieron la cocina completa a medida y quedó perfecta. Muy profesionales, puntuales y el resultado superó todas las expectativas.',
    avatar: 'MG',
  },
  {
    name: 'Carlos Martínez',
    rating: 5,
    date: 'Hace 1 mes',
    text: 'Contraté a López y Vidal para unos armarios empotrados y unos muebles de baño. El trabajo fue impecable, los acabados perfectos y el trato excelente.',
    avatar: 'CM',
  },
  {
    name: 'Ana Pérez',
    rating: 5,
    date: 'Hace 2 meses',
    text: 'Increíbles profesionales. Nos renovaron toda la carpintería de la casa — puertas, ventanas, tarima y escalera. Todo perfecto y dentro del plazo.',
    avatar: 'AP',
  },
  {
    name: 'José Luis Sánchez',
    rating: 5,
    date: 'Hace 3 meses',
    text: 'Trabajo de CNC para un proyecto especial. Precisión milimétrica, atención al detalle impresionante. Totalmente recomendables para proyectos exigentes.',
    avatar: 'JS',
  },
];
---

<section id="resenas" class="section-pad" style="background-color: #ffffff;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12">
      <span
        class="inline-block text-sm font-semibold uppercase tracking-widest mb-3"
        style="color: #067538;"
      >
        Opiniones verificadas
      </span>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-gray-900 mb-4">
        Lo que Dicen Nuestros Clientes
      </h2>

      <!-- Google rating badge -->
      <div class="inline-flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-2xl px-6 py-3 mb-6">
        <svg class="w-6 h-6" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <div>
          <div class="flex items-center gap-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
            <span class="font-bold text-gray-900 ml-1">5.0</span>
          </div>
          <p class="text-xs text-gray-500">Google Reviews</p>
        </div>
        <a
          href="https://maps.app.goo.gl/ehNcNENWVEACRM6v8"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium hover:underline"
          style="color: #067538;"
        >
          Ver en Google →
        </a>
      </div>

      <div class="mt-2 w-16 h-1 mx-auto rounded-full" style="background-color: #f5a623;"></div>
    </div>

    <!--
      === ELFSIGHT GOOGLE REVIEWS WIDGET ===
      Instrucciones para activar las reseñas reales de Google:
      1. Registrarse en https://elfsight.com
      2. Crear un widget "Google Reviews"
      3. Buscar "Carpintería López y Vidal" o pegar la URL de Google Maps
      4. Copiar el snippet HTML generado y reemplazar el div de abajo
      5. El snippet tiene el formato: <div class="elfsight-app-XXXXXXXX-..."></div>
         más el script: <script src="https://static.elfsight.com/platform/platform.js"></script>
    -->

    <!-- Elfsight widget placeholder — reemplazar con el snippet real -->
    <div
      id="elfsight-reviews-placeholder"
      class="border-2 border-dashed rounded-2xl p-8 text-center mb-8"
      style="border-color: #09a64f; background-color: #f4f8f5;"
    >
      <p class="font-semibold mb-2" style="color: #067538;">Widget de Reseñas Google</p>
      <p class="text-sm text-gray-500 mb-4">
        Registrar cuenta en <strong>Elfsight.com</strong>, crear widget "Google Reviews" y reemplazar este bloque con el snippet HTML.
      </p>
      <a
        href="https://elfsight.com/google-reviews-widget/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-white px-4 py-2 rounded-full"
        style="background-color: #067538;"
      >
        Configurar widget →
      </a>
    </div>

    <!-- Static review cards (fallback / complementary) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {staticReviews.map((review) => (
        <article class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-3" aria-label={`${review.rating} de 5 estrellas`}>
            {Array.from({ length: review.rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Review text -->
          <blockquote class="text-gray-700 text-sm leading-relaxed mb-4">
            "{review.text}"
          </blockquote>

          <!-- Reviewer -->
          <div class="flex items-center gap-3">
            <div
              class="w-9 h-9 rounded-full text-white text-sm font-bold flex items-center justify-center flex-shrink-0"
              style="background-color: #067538;"
              aria-hidden="true"
            >
              {review.avatar}
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">{review.name}</p>
              <p class="text-xs text-gray-400">{review.date} · Google</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA to leave a review -->
    <div class="text-center mt-10">
      <p class="text-gray-600 mb-4">¿Ya trabajaste con nosotros? ¡Déjanos tu opinión!</p>
      <a
        href="https://maps.app.goo.gl/ehNcNENWVEACRM6v8"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border-2 font-semibold px-6 py-3 rounded-full hover:opacity-80 transition-opacity"
        style="border-color: #067538; color: #067538;"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        </svg>
        Escribir una reseña en Google
      </a>
    </div>
  </div>
</section>
