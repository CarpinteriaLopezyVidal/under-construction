---

<footer style="background-color: #044d25;" class="text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div
            class="w-12 h-12 rounded-full border-2 border-white/30 flex items-center justify-center bg-white/10"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7l9-4 9 4M3 7v10l9 4m-9-4l9 4m0 0l9-4M12 11V21M3 7l9 4 9-4"/>
            </svg>
          </div>
          <div>
            <p class="font-display font-bold text-lg leading-tight">Carpintería</p>
            <p class="font-display font-bold text-lg leading-tight" style="color: #f5a623;">López y Vidal</p>
          </div>
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          Artesanía en madera de calidad desde Pinoso, Alicante.
          Proyectos personalizados para toda España y el extranjero.
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3" role="list" aria-label="Redes sociales">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              aria-label={link.label}
              role="listitem"
              class="w-9 h-9 rounded-full flex items-center justify-center text-white bg-white/10 hover:bg-white/20 transition-colors"
            >
              <Fragment set:html={link.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="font-semibold text-white mb-5 uppercase tracking-wider text-sm">Navegación</h3>
        <ul class="space-y-2.5">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors text-sm flex items-center gap-2">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="font-semibold text-white mb-5 uppercase tracking-wider text-sm">Contacto</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2 text-white/70">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            <span>Pinoso, Alicante, España<br/><span class="text-white/50 text-xs">Servicio en toda España y extranjero</span></span>
          </li>
          <li>
            <a href="tel:+34649669311" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              +34 649 669 311
            </a>
          </li>
          <li>
            <a href="mailto:web@carpinterialopezyvidal.com" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors break-all">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              web@carpinterialopezyvidal.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/50">
      <p>© {year} Carpintería López y Vidal · Pinoso, Alicante</p>
      <p>
        Hecho con ❤️ y madera de calidad
      </p>
    </div>
  </div>
</footer>
