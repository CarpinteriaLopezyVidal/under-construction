---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="padding-top: 4rem;"
>
  <!-- Background image layer -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/gallery/slide-one.jpg');"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay -->
  <div class="absolute inset-0" style="background-color: rgba(4, 77, 37, 0.82);" aria-hidden="true"></div>

  <!-- Subtle wood grain texture overlay -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto py-16">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/30 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6">
      <span>📍</span>
      <span>Pinoso, Alicante · Toda España y Extranjero</span>
    </div>

    <!-- Main heading -->
    <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-tight mb-6">
      Carpintería<br />
      <span style="color: #f5a623;">López y Vidal</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl sm:text-2xl text-white/90 max-w-3xl mx-auto mb-4 leading-relaxed">
      Transformamos la madera en <strong class="text-white">obras únicas</strong>.
      Desde proyectos íntimos hasta retos de gran escala — sin límites.
    </p>

    <p class="text-base sm:text-lg text-white/75 max-w-2xl mx-auto mb-10">
      Artesanía tradicional, tecnología CNC y pasión por los detalles al servicio de tus sueños.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a
        href="#contacto"
        style="background-color: #f5a623;"
        class="inline-flex items-center gap-2 text-white font-bold px-8 py-4 rounded-full text-lg shadow-xl hover:opacity-90 transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Solicitar presupuesto
      </a>
      <a
        href="#galeria"
        class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/25 transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Ver nuestros trabajos
      </a>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
      {[
        { value: '+15', label: 'Años de experiencia' },
        { value: '100%', label: 'Proyectos a medida' },
        { value: '🇪🇸', label: 'Toda España' },
        { value: '🌍', label: 'También extranjero' },
      ].map(({ value, label }) => (
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-3">
          <div class="text-2xl font-bold text-white">{value}</div>
          <div class="text-xs text-white/75 mt-0.5">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <a href="#servicios" aria-label="Ver servicios">
      <svg class="w-6 h-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>
