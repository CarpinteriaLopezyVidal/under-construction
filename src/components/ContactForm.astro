---
const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#';
const hcaptchaSiteKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY || '';

const services = [
  'Carpintería artesanal en madera',
  'Trabajos de CNC',
  'Proyecto personalizado',
  'Cocina a medida',
  'Vivienda completa',
  'Transporte e instalación',
  'Otro',
];
---

<section id="contacto" class="section-pad" style="background-color: #ffffff;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12">
      <span
        class="inline-block text-sm font-semibold uppercase tracking-widest mb-3"
        style="color: #067538;"
      >
        Hablemos
      </span>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-gray-900 mb-4">
        Contacta con Nosotros
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Cuéntanos tu proyecto y te responderemos en menos de 24 horas. Sin compromiso.
      </p>
      <div class="mt-5 w-16 h-1 mx-auto rounded-full" style="background-color: #f5a623;"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

      <!-- Contact form (3/5 width on desktop) -->
      <div class="lg:col-span-3">
        <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-lg">
          <form
            id="contact-form"
            action={`https://formspree.io${formspreeEndpoint}`}
            method="POST"
            novalidate
          >
            <!-- Hidden fields for Formspree -->
            <input type="hidden" name="_subject" value="Nuevo mensaje desde carpinterialopezyvidal.com" />
            <input type="hidden" name="_language" value="es" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Nombre completo <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Tu nombre"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 transition-all"
                  style="focus:ring-color: #067538;"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+34 600 000 000"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 transition-all"
                />
              </div>
            </div>

            <!-- Email -->
            <div class="mb-5">
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Email <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@email.com"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 transition-all"
              />
            </div>

            <!-- Service -->
            <div class="mb-5">
              <label for="service" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Tipo de servicio
              </label>
              <select
                id="service"
                name="service"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 transition-all bg-white appearance-none cursor-pointer"
              >
                <option value="">Selecciona un servicio...</option>
                {services.map(s => <option value={s}>{s}</option>)}
              </select>
            </div>

            <!-- Message -->
            <div class="mb-6">
              <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Cuéntanos tu proyecto <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                placeholder="Describe tu proyecto, dimensiones aproximadas, materiales que te gustan, plazos..."
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 transition-all resize-none"
              ></textarea>
            </div>

            <!-- hCaptcha widget -->
            <!--
              Instrucciones para activar hCaptcha:
              1. Registrar cuenta en https://hcaptcha.com
              2. Crear un sitio para www.carpinterialopezyvidal.com
              3. Copiar la Site Key
              4. Añadir como secret HCAPTCHA_SITE_KEY en GitHub Actions
              5. En Formspree: Settings > Spam Filtering > activar hCaptcha
            -->
            {hcaptchaSiteKey ? (
              <div
                class="h-captcha mb-6"
                data-sitekey={hcaptchaSiteKey}
                data-theme="light"
              ></div>
            ) : (
              <div
                class="border border-dashed border-gray-300 rounded-xl p-4 mb-6 text-center text-sm text-gray-500"
              >
                <strong>CAPTCHA</strong> — Configurar <code>PUBLIC_HCAPTCHA_SITE_KEY</code> en GitHub Secrets para activar hCaptcha.
              </div>
            )}

            <!-- Submit button -->
            <button
              type="submit"
              id="submit-btn"
              style="background-color: #067538;"
              class="w-full text-white font-bold py-4 px-8 rounded-xl hover:opacity-90 transition-all duration-200 flex items-center justify-center gap-2 text-lg"
            >
              <span id="btn-text">Enviar mensaje</span>
              <svg id="btn-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>

            <!-- Success / error messages -->
            <div id="form-success" class="hidden mt-4 bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 text-sm font-medium" role="alert">
              ✅ ¡Mensaje enviado! Te responderemos pronto.
            </div>
            <div id="form-error" class="hidden mt-4 bg-red-50 border border-red-200 text-red-800 rounded-xl px-4 py-3 text-sm font-medium" role="alert">
              ❌ Hubo un error al enviar. Por favor, inténtalo de nuevo o escríbenos directamente.
            </div>
          </form>
        </div>
      </div>

      <!-- Contact info (2/5 width on desktop) -->
      <div class="lg:col-span-2 space-y-5">

        <!-- Contact details card -->
        <div class="rounded-3xl p-7 text-white" style="background-color: #067538;">
          <h3 class="font-display font-bold text-xl mb-6">Información de Contacto</h3>

          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <div class="mt-0.5 w-8 h-8 bg-white/15 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Ubicación</p>
                <p class="text-white/80 text-sm">Pinoso, Alicante, España</p>
                <p class="text-white/60 text-xs mt-0.5">Servicio en toda España y extranjero</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-0.5 w-8 h-8 bg-white/15 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Teléfono</p>
                <a href="tel:+34649669311" class="text-white hover:text-yellow-300 transition-colors text-sm font-medium">
                  +34 649 669 311
                </a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-0.5 w-8 h-8 bg-white/15 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Email</p>
                <a href="mailto:web@carpinterialopezyvidal.com" class="text-white/90 hover:text-white transition-colors text-sm break-all">
                  web@carpinterialopezyvidal.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-0.5 w-8 h-8 bg-white/15 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Horario</p>
                <p class="text-white/80 text-sm">Lun–Vie: 8:00 – 18:00</p>
                <p class="text-white/60 text-xs">Sáb: previa cita</p>
              </div>
            </div>
          </div>
        </div>

        <!-- WhatsApp CTA card -->
        <a
          href="https://wa.me/34649669311?text=Hola%2C%20me%20gustar%C3%ADa%20pedir%20informaci%C3%B3n%20sobre%20vuestros%20servicios"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-6 rounded-3xl text-white hover:opacity-95 transition-opacity shadow-lg"
          style="background-color: #25D366;"
          aria-label="Contactar por WhatsApp"
        >
          <div class="flex-shrink-0" aria-hidden="true">
            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.559 4.122 1.532 5.852L0 24l6.335-1.51A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.798 9.798 0 01-4.992-1.365l-.358-.213-3.76.896.958-3.658-.235-.376A9.782 9.782 0 012.182 12C2.182 6.578 6.578 2.182 12 2.182S21.818 6.578 21.818 12 17.422 21.818 12 21.818z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-lg leading-tight">Escríbenos por WhatsApp</p>
            <p class="text-white/85 text-sm">Respuesta inmediata · +34 649 669 311</p>
          </div>
        </a>

        <!-- Google Maps embed -->
        <div class="rounded-3xl overflow-hidden shadow-md">
          <iframe
            title="Ubicación Carpintería López y Vidal en Pinoso, Alicante"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12415.58!2d-1.0339!3d38.3987!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd63e22d30e52be3%3A0x0!2sPinoso%2C+Alicante!5e0!3m2!1ses!2ses!4v1"
            width="100%"
            height="220"
            style="border: 0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- hCaptcha script (loads only when site key is set) -->
{hcaptchaSiteKey && (
  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
)}

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnIcon = document.getElementById('btn-icon');
  const btnSpinner = document.getElementById('btn-spinner');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate required fields
    const name = (form.querySelector('#name') as HTMLInputElement)?.value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement)?.value.trim();
    const message = (form.querySelector('#message') as HTMLTextAreaElement)?.value.trim();

    if (!name || !email || !message) {
      alert('Por favor, rellena todos los campos obligatorios (*).');
      return;
    }

    // Show loading state
    if (btnText) btnText.textContent = 'Enviando...';
    btnIcon?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');
    if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    } finally {
      if (btnText) btnText.textContent = 'Enviar mensaje';
      btnIcon?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
